# ==============================================
# LLM 大模型配置
# ==============================================
LLM_TYPE=ALIYUN

# ==============================================
# Ollama 配置（LLM_TYPE=OLLAMA 时生效）
# ==============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=qwen3.5:0.8b

# ==============================================
# 阿里云百炼配置
# ==============================================
ALIYUN_ACCESS_KEY_SECRET=sk-6e8b42c50fe24e678f9fda345934158a
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CHAT_MODEL_NAME=qwen3-max

# ==============================================
# 向量嵌入模型配置
# ==============================================
# 这里使用阿里云百炼的嵌入模型，与 LLM 同一生态
EMBED_MODEL_TYPE=ALIYUN
TEXT_EMBEDDING_MODEL_NAME=qwen3-embedding:0.6b   # 当 EMBED_MODEL_TYPE=OLLAMA 时有效
ALIYUN_EMBED_MODEL_NAME=text-embedding-v4        # 百炼通用文本嵌入模型

# ==============================================
# 数据库配置
# ==============================================
MYSQL_USER=root
MYSQL_PASSWORD=qwe123FGDF..
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=chat_history

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==============================================
# JWT 身份验证配置
# ==============================================
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==============================================
# Skills 技能系统配置（新增）
# ==============================================
SKILLS_ROOT=./skills
SKILL_DEFAULT_SELECT_STRATEGY=llm       # keyword / llm

# ==============================================
# LangSmith 调试追踪（按需开启）
# ==============================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=my-fastapi-langchain-project

# ==============================================
# 重排序模型配置
# ==============================================
RERANKER_MODEL_PATH=D:\Hugging_Face\models\Qwen3-Reranker-0.6B

# ==============================================
# RAG 核心参数
# ==============================================
RETRIEVAL_TOP_K=5
CHUNK_SIZE=200
CHUNK_OVERLAP=20
RERANK_TOP_K=3
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=txt,pdf,md,docx
